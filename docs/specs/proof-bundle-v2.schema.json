{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vellum.io/specs/proof-bundle-v2.schema.json",
  "title": "Vellum Proof Bundle v2",
  "type": "object",
  "required": [
    "spec",
    "bundle_id",
    "hashing",
    "issuer",
    "signature",
    "watermark",
    "anchors",
    "verification_hints"
  ],
  "properties": {
    "spec": { "type": "string", "const": "vellum-proof-bundle/v2" },
    "bundle_id": { "type": "string", "pattern": "^vpb2_[0-9a-f]{64}$" },
    "hashing": {
      "type": "object",
      "required": ["algorithm", "text_hash", "input_encoding", "normalization"],
      "properties": {
        "algorithm": { "type": "string", "const": "sha256" },
        "text_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "input_encoding": { "type": "string", "const": "utf-8" },
        "normalization": { "type": "string" }
      }
    },
    "issuer": {
      "type": "object",
      "required": ["issuer_id", "name", "eth_address", "public_key_hex"],
      "properties": {
        "issuer_id": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "eth_address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
        "public_key_hex": { "type": "string" }
      }
    },
    "signature": {
      "type": "object",
      "required": ["scheme", "signed_payload", "signature_hex", "recoverable_address"],
      "properties": {
        "scheme": { "type": "string", "const": "eip191_personal_sign" },
        "signed_payload": { "type": "string" },
        "signature_hex": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" },
        "recoverable_address": { "type": "boolean" }
      }
    },
    "watermark": {
      "type": "object",
      "required": ["detected", "tag_count", "valid_count", "invalid_count", "payloads"],
      "properties": {
        "detected": { "type": "boolean" },
        "tag_count": { "type": "integer", "minimum": 0 },
        "valid_count": { "type": "integer", "minimum": 0 },
        "invalid_count": { "type": "integer", "minimum": 0 },
        "payloads": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "schema_version",
              "issuer_id",
              "model_id",
              "model_version_id",
              "key_id",
              "crc_valid",
              "raw_payload_hex"
            ]
          }
        }
      }
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "block_num", "timestamp", "data_hash"],
        "properties": {
          "type": { "type": "string", "enum": ["simulated_chain", "solana"] },
          "network": { "type": "string" },
          "block_num": { "type": "integer", "minimum": 0 },
          "timestamp": { "type": "string" },
          "data_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "tx_hash": { "type": "string" },
          "tx_signature": { "type": "string" }
        }
      }
    },
    "verification_hints": {
      "type": "object",
      "required": ["chain_type"],
      "properties": {
        "chain_type": { "type": "string", "enum": ["simulated", "solana"] },
        "cluster": { "type": "string" },
        "rpc_urls": { "type": "array", "items": { "type": "string" } },
        "explorer_url": { "type": "string" },
        "memo_program": { "type": "string" }
      }
    }
  }
}
