# Veritext canonical environment template
# Copy to .env and edit as needed.

# === Core ===
DEMO_MODE=live                              # live | fixture
REGISTRY_ADMIN_SECRET=dev-admin-secret-change-me

# === Server ===
APP_HOST=127.0.0.1
APP_PORT=5050
CORS_ORIGINS=http://localhost:5173,http://localhost:5050
LOG_LEVEL=info
LOG_FORMAT=pretty                           # pretty | json

# === Database ===
DB_PATH=data/veritext.db

# === LLM Providers ===
GOOGLE_API_KEY=

# === Watermark ===
WATERMARK_INJECTION_MODE=whitespace         # whitespace | grapheme
PAYLOAD_VISIBILITY=plaintext                # plaintext | encrypted
WATERMARK_ENCRYPTION_KEY=                   # 32-hex-char (16 bytes) when PAYLOAD_VISIBILITY=encrypted
GENWATERMARK_ENABLED=false                  # SynthID-Text generation-time layer

# === Chain Backend ===
CHAIN_BACKEND=simulated                     # simulated | solana
ANCHOR_STRATEGY=per_response                # per_response | merkle_batch
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR_PATH=
SOLANA_CLUSTER=devnet
MERKLE_BATCH_WINDOW_SECONDS=10
MERKLE_BATCH_MAX_LEAVES=64

# === Auth0 (Optional) ===
AUTH0_DOMAIN=                               # e.g., veritext.us.auth0.com
AUTH0_AUDIENCE=https://api.veritext.io
AUTH0_SPA_CLIENT_ID=
JWKS_CACHE_TTL_SECONDS=300
